# Eral environment variables
# Secrets should be set via: wrangler secret put <NAME>
# Never commit real values to source control.

# ── Required ─────────────────────────────────────────────────────────────────
# Shared with WokAPI — must match exactly
JWT_SECRET=<openssl rand -hex 32>

# ── AI Providers ─────────────────────────────────────────────────────────────
# Free-first default: Cloudflare Workers AI via the Wrangler AI binding.
# Eral now prefers Cloudflare AI unless AI_PROVIDER=openai is set.
AI_PROVIDER=cloudflare

# Cloudflare Workers AI model overrides
# Default: @cf/meta/llama-3.3-70b-instruct-fp8-fast
CF_AI_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast

# Fallback when the primary Cloudflare model is unavailable
# Default: @cf/meta/llama-3.1-8b-instruct-fp8-fast
CF_AI_FALLBACK_MODEL=@cf/meta/llama-3.1-8b-instruct-fp8-fast

# Optional OpenAI model override
OPENAI_MODEL=gpt-4o

# Optional paid provider
OPENAI_API_KEY=sk-...

# ── Optional ─────────────────────────────────────────────────────────────────
# Error tracking
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# Deployment environment (set in wrangler.toml [vars])
ENVIRONMENT=development
